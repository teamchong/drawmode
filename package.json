{
  "name": "drawmode",
  "version": "0.1.0",
  "packageManager": "pnpm@10.21.0",
  "description": "Code Mode MCP server for generating Excalidraw architecture diagrams with auto-layout",
  "type": "module",
  "bin": {
    "drawmode": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "{ cd wasm && zig build && ./optimize-wasm.sh && cd ..; } || echo 'Zig not available, skipping WASM build'; tsc && cp src/widget.html dist/widget.html",
    "build:wasm": "cd wasm && zig build && ./optimize-wasm.sh",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "docs:dev": "cd docs && npx astro dev",
    "docs:build": "cd docs && npx astro build"
  },
  "keywords": [
    "mcp",
    "excalidraw",
    "diagram",
    "codemode",
    "architecture",
    "wasm"
  ],
  "files": [
    "dist",
    "!dist/*.test.*",
    "wasm/zig-out/bin/drawmode.wasm",
    "README.md",
    "LICENSE"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "pnpm": {
    "overrides": {
      "hono": ">=4.12.4",
      "@hono/node-server": ">=1.19.10",
      "qs": ">=6.14.2",
      "ajv": ">=8.18.0",
      "rollup": ">=4.59.0"
    }
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "zod": "^3.23.0"
  },
  "optionalDependencies": {
    "puppeteer": "^24.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/pngjs": "^6.0.5",
    "pixelmatch": "^7.1.0",
    "pngjs": "^7.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.5.0",
    "vitest": "^3.0.0"
  }
}
