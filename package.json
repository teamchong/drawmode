{
  "name": "drawmode",
  "version": "0.1.0",
  "description": "Code Mode MCP server for generating Excalidraw architecture diagrams with auto-layout",
  "type": "module",
  "bin": {
    "drawmode": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "{ cd wasm && zig build && cd ..; } || echo 'Zig not available, skipping WASM build'; tsc && cp src/widget.html dist/widget.html",
    "build:wasm": "cd wasm && zig build",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "mcp",
    "excalidraw",
    "diagram",
    "codemode",
    "architecture",
    "wasm"
  ],
  "files": [
    "dist",
    "!dist/*.test.*",
    "wasm/zig-out/bin/drawmode.wasm",
    "README.md",
    "LICENSE"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.25.0",
    "zod": "^3.23.0"
  },
  "optionalDependencies": {
    "puppeteer": "^24.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.5.0",
    "vitest": "^3.0.0"
  }
}
